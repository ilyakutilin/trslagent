# LLM Settings
# LLM Base URL
LLM__BASE_URL=https://openrouter.ai/api/v1

# LLM API key (required)
LLM__API_KEY=your-api-key-here

# Model to use for translation
LLM__MODEL=anthropic/claude-3.5-sonnet

# Temperature for translation (0.0 = most consistent/literal, 1.0 = more creative)
LLM__TEMPERATURE=0.1

# Reasoning effort for the thinking models. If not provided, reasoning is not used.
# Allowed values: none, minimal, low, medium, high, xhigh
LLM__REASONING_EFFORT=high

# Chunking Settings
# Maximum chunk size in characters (approximately 6000/4 = 1500 tokens)
CHUNK__SIZE=6000

# Overlap between chunks in characters to maintain context
CHUNK__OVERLAP=600

# Glossary Settings
# Directory with glossary XML files exported by Multiterm
GLOSSARY__XML_DIR=./files/glossary

# Number of glossary terms to retrieve per chunk
GLOSSARY__TOP_K=20

# Path to a file with a list of known abbreviations
GLOSSARY__KNOWN_ABBRS_FILE_PATH=files/abbrs

# Google Docs Settings
# Path to the Google service account JSON credentials file
GDOCS__CREDENTIALS_PATH=credentials/credentials.json

# ID of the Google Doc used as input (from the doc URL)
GDOCS__DOCUMENT_ID=doc_id

# How often (seconds) to check the document for new requests
GDOCS__POLL_INTERVAL_SECONDS=15

# Value of the Status field that triggers processing
GDOCS__READY_TRIGGER=Ready

# Value written to Status after successful processing
GDOCS__DONE_MARKER=Done

# Value written to Status if processing fails
GDOCS__ERROR_MARKER=Error

# Logging Settings
LOG__LEVEL=INFO
# LOG__FORMAT=<custom format string>
