# LLM Settings
# OpenRouter API key (required)
LLM__API_KEY=your-openrouter-api-key-here

# Model to use for translation
LLM__MODEL=anthropic/claude-3.5-sonnet

# Temperature for translation (0.0 = most consistent/literal, 1.0 = more creative)
LLM__TEMPERATURE=0.1

# Chunking Settings
# Maximum chunk size in characters (approximately 6000/4 = 1500 tokens)
CHUNK__SIZE=6000

# Overlap between chunks in characters to maintain context
CHUNK__OVERLAP=600

# Glossary Settings
# Number of glossary terms to retrieve per chunk
GLOSSARY__TOP_K=20

# Sentence transformer model for embeddings
GLOSSARY__EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Directory for ChromaDB persistence
GLOSSARY__CHROMA_DIR=./chromadb

# ChromaDB collection name
GLOSSARY__COLLECTION_NAME=glossary

# Glossary Embedding Batch Size
# Number of terms to embed and upsert in each batch (smaller = more frequent saves)
# Default: 100 (with ~7000 terms = 70 batches, each upserting 200 entries)
GLOSSARY__EMBED_BATCH_SIZE=100

# Logging Settings
LOG__LEVEL=INFO
# LOG__FORMAT=<custom format string>
