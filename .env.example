# LLM Settings
# LLM Base URL
LLM__BASE_URL=https://openrouter.ai/api/v1

# LLM API key (required)
LLM__API_KEY=your-api-key-here

# Model to use for translation
LLM__MODEL=anthropic/claude-3.5-sonnet

# Temperature for translation (0.0 = most consistent/literal, 1.0 = more creative)
LLM__TEMPERATURE=0.1

# Reasoning effort for the thinking models. If not provided, reasoning is not used.
# Allowed values: none, minimal, low, medium, high, xhigh
LLM__REASONING_EFFORT=high

# Chunking Settings
# Maximum chunk size in characters (approximately 6000/4 = 1500 tokens)
CHUNK__SIZE=6000

# Character for manual chunk splitting (e.g. "-" splits on "----------")
# When set, overrides size-based chunking
# CHUNK__DIVIDER=-

# Max simultaneous LLM API calls per task (helps avoid 429 rate limits)
CHUNK__MAX_CONCURRENT=3

# Delay in seconds between launching chunk tasks (staggering to avoid rate limits)
CHUNK__DELAY_SECONDS=1.5

# Glossary Settings
# Directory with glossary XML files exported by Multiterm
GLOSSARY__XML_DIR_PATH=./files/glossary

# Path to a file with a list of known abbreviations
GLOSSARY__KNOWN_ABBRS_FILE_PATH=files/abbrs

# Logging Settings
LOG__LEVEL=INFO
# LOG__FORMAT=<custom format string>

# Cost Tracking Settings
# URL for retrieving generation cost info via completion ID; set to enable cost display
# COST__GENERATION_INFO_URL=https://openrouter.ai/api/v1/generation
# COST__COST_KEY=total_cost
# COST__COST_CURRENCY=USD
